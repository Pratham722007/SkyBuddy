<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/background">

    <TextView
        android:id="@+id/tv_my_shop_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Shop"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_my_shop_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap a shop to edit its details."
        android:textSize="16sp"
        android:textColor="@color/text_grey"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_my_shop_title"
        app:layout_constraintStart_toStartOf="parent" />
        
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_my_shops"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/tv_my_shop_desc"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_shop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="90dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/primary_accent"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
