<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.skybeacon.ui.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.skybeacon.ui.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboardFragment_to_broadcastManagementFragment"
            app:destination="@id/broadcastManagementFragment" />
    </fragment>

    <fragment
        android:id="@+id/broadcastManagementFragment"
        android:name="com.example.skybeacon.ui.BroadcastManagementFragment"
        android:label="Broadcast Management"
        tools:layout="@layout/fragment_broadcast_management">
        <argument
            android:name="shopId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/myShopFragment"
        android:name="com.example.skybeacon.ui.MyShopFragment"
        android:label="My Shop"
        tools:layout="@layout/fragment_my_shop" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.skybeacon.ui.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>
</navigation>
